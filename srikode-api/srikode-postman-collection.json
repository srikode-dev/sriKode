          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.token) {",
                  "    // Extract JWT token from 'Bearer eyJhbG...'",
                  "    const token = response.token.split(\" \")[1];",
                  "    pm.environment.set(\"jwt_token\", token);",
                  "    console.log(\"Saved jwt_token env variable: \", token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"srikantsahu.dev@gmail.com\",\n  \"password\": \"your_password_here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
